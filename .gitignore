# ─────────────────────────────────────────────────────────────
# JobHunt — keep personal data and sessions OUT of git
# ─────────────────────────────────────────────────────────────

# Your past resumes / personal documents
past_cv/*
!past_cv/.gitkeep
!past_cv/README.md

# Compiled personal profile (generated by /build-info)
info.txt

# Your actual search scope (a template scope.txt is committed)
scope.txt

# Generated job applications (folders with posting/resume/cover letter)
output/*
!output/.gitkeep

# Your live tracking sheet (a template is committed)
applications.csv

# Persistent browser session — contains login cookies for LinkedIn etc.
.browser-profile/

# Secrets
.env
*.local

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/

# Node (Playwright MCP may cache things locally)
node_modules/

# Playwright MCP runtime artifacts (console logs + page snapshots of scraped jobs)
.playwright-mcp/
